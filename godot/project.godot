; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Simple Card Battle"
run/main_scene="res://Menu.tscn"
config/features=PackedStringArray("4.7")
config/icon="res://icon.png"

[autoload]

Game="*res://Game.gd"
Network="*res://Network.gd"
SceneRoutes="*res://autoload/SceneRoutes.gd"
SaveService="*res://autoload/SaveService.gd"
UiUtils="*res://autoload/UiUtils.gd"
Events="*res://autoload/Events.gd"
GameState="*res://autoload/GameState.gd"
PlatformBridge="*res://autoload/PlatformBridge.gd"
Navigator="*res://autoload/Navigator.gd"
AutoplayBot="*res://autoload/AutoplayBot.gd"
StressTestRunner="*res://autoload/StressTestRunner.gd"
DebugCLI="*res://autoload/DebugCLI.gd"
AudioManager="*res://autoload/AudioManager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/resizable=false
window/size/window_width_override=360
window/size/window_height_override=640
window/stretch/mode="2d"
window/stretch/aspect="expand"
window/handheld/orientation="portrait"
mouse_cursor/custom_image="res://hand-up.png"
mouse_cursor/custom_image_hotspot=Vector2(13, 0)

[editor]

convert_text_resources_to_binary_on_export=true

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp_enhanced/plugin.cfg")

